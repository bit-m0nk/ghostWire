# GhostWire — Frontend Builder Dockerfile
# One-shot container: builds the Vue SPA and exits.
# Output lands in the ghostwire-dist volume, mounted by the backend.

FROM node:20-alpine

WORKDIR /app

# Install deps layer (cached if package.json unchanged)
COPY frontend/package*.json ./
RUN npm ci --silent

# Copy source and build
COPY frontend/ ./
RUN npm run build

# The compose file mounts ghostwire-dist and copies dist/* there at runtime
